---
import { formatDistanceToNow, differenceInMonths } from "date-fns";

interface Props {
  title: string;
  description?: string;
  slug: string;
  url: string;
  date?: Date;
  tags?: string[];
  excerpt?: string;
  index: number;
  visual?: {
    colors?: Array<{ text: string; background: string }>;
    prompt?: string;
  };
  hero?: boolean;
  className?: string;
}

const { 
  title, 
  description, 
  slug, 
  url,
  date,
  tags = [], 
  excerpt,
  index, 
  visual,
  hero = false, 
  className = "" 
} = Astro.props;

// Get colors from visual config
const colors = visual?.colors?.[index];
const backgroundColor = colors?.background || "#f5f5f5";
const textColor = colors?.text || "#1a1a1a";

// Date caption
const dateCaption = date ? `${formatDistanceToNow(date)} ago` : null;
const isOldArticle = date ? differenceInMonths(new Date(), date) > 12 : false;

// Target path with visual index (1-indexed for user-facing URLs)
const targetPath = `${url}/${index + 1}`;
---

<a
  href={targetPath}
  style={`--background: ${backgroundColor}; --text: ${textColor};`}
  class:list={[
    "nav-block @container text-[var(--text)] bg-[var(--background)] overflow-hidden flex group rounded-md relative ring-transparent ring-offset-1 dark:ring-offset-gray-950 hover:ring-[var(--background)] hover:ring-3 focus-visible:ring-[var(--background)] focus-visible:ring-3 outline-none transition-opacity duration-300",
    hero ? "justify-center flex-col-reverse" : "justify-between flex-col-reverse sm:flex-col",
    className
  ]}
>
  <div class="flex flex-col p-4 flex-1 min-h-0 justify-between">
    <div class="space-y-2 sm:space-y-4 flex-shrink-0">
      <div class="flex justify-between relative z-10">
        <div class:list={[
          "max-w-4xl flex w-0 flex-1 flex-col items-start flex-wrap gap-x-2",
          description ? "gap-y-2" : "gap-y-0"
        ]}>
          <div class="text-xs relative whitespace-nowrap w-full z-10 flex gap-2 items-center overflow-hidden [mask-image:linear-gradient(to_right,black_calc(100%-2rem),transparent)]">
            {dateCaption && (
              <span class:list={[
                "font-semibold px-2 rounded-full",
                isOldArticle 
                  ? "border border-[var(--text)]/30 text-[var(--text)]" 
                  : "bg-[var(--text)] text-[var(--background)]"
              ]}>
                {dateCaption}
              </span>
            )}
            {tags.map((tag) => (
              <span class="font-semibold px-1.5 border rounded-full border-current/30">
                {tag}
              </span>
            ))}
          </div>
          <div class:list={[
            "font-heading text-pretty space-x-2 flex flex-col items-start font-semibold",
            hero ? "text-3xl sm:text-4xl" : "text-3xl sm:text-3xl sm:leading-8"
          ]}>
            {title}
          </div>
        </div>
      </div>
      {description && (
        <div class="relative z-10">
          <div class:list={[
            "overflow-hidden max-w-lg text-current/80 font-mono font-semibold",
            hero ? "sm:text-lg" : "text-sm"
          ]}>
            {description}
          </div>
        </div>
      )}
    </div>
    {hero && excerpt && (
      <div class="flex-1 min-h-0 relative overflow-hidden mt-4">
        <div class="absolute inset-0 flex pointer-events-none mask-b-from-80% mask-b-to-100%">
          <div class="max-w-4xl text-base text-current/50 leading-snug whitespace-pre-wrap h-fit">
            {excerpt}
          </div>
        </div>
      </div>
    )}
    {hero && (
      <div class="md:pt-8">
        <span class="absolute bottom-0 rounded-t-sm self-start px-4 py-2 bg-[var(--text)]/90 text-[var(--background)] font-semibold max-md:hidden">
          Read more
        </span>
      </div>
    )}
  </div>
  <div class:list={[
    "-mb-8 flex items-center justify-center relative w-full aspect-square shrink-0 overflow-hidden rounded-md",
    hero ? "sm:-mb-48" : "sm:mb-0"
  ]}>
    <img
      src={`/posts/${slug}/${index}.png`}
      alt={title}
      class:list={[
        hero 
          ? "mask-b-from-40% mask-b-to-80%" 
          : "max-sm:mask-b-to-100% max-sm:mask-b-from-80% sm:mask-t-from-95% sm:mask-t-to-100%"
      ]}
    />
  </div>
</a>
