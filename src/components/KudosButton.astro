---
interface Props {
  slug: string;
  total: number;
  you: number;
  currentPath: string;
}

const { slug, total, you, currentPath } = Astro.props;

const remaining = Math.max(0, 50 - you);
const disabled = remaining <= 0;
---

<form
  method="POST"
  action="/api/kudos"
  class="kudos-form inline-block"
  data-slug={slug}
  data-total={total}
  data-you={you}
>
  <input type="hidden" name="slug" value={slug} />
  <input type="hidden" name="redirectTo" value={currentPath} />
  <button
    type="submit"
    disabled={disabled}
    aria-label="Give kudos"
    title={disabled ? "Limit reached" : "Give kudos"}
    class:list={[
      "kudos-button font-mono bg-white dark:bg-gray-950 relative z-10 inline-flex items-center gap-2 px-3 py-2 border border-indigo-600/50 dark:border-indigo-400/50 text-indigo-600 dark:text-indigo-400 focus-ring-primary transition-colors",
      disabled
        ? "border-current/20 cursor-not-allowed"
        : "hover:border-indigo-400 hover:text-indigo-500 hover:dark:text-indigo-300 cursor-pointer",
    ]}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M7 10v12" />
      <path
        d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z"
      />
    </svg>
    <span class="kudos-total font-semibold">{total}</span>
    <span class="text-xs opacity-70">
      (<span class="kudos-remaining">{remaining}</span> left)
    </span>
  </button>
</form>

<script>
  interface ConfettiBurst {
    id: string;
    element: HTMLDivElement;
  }

  function createConfetti(container: HTMLElement): HTMLDivElement {
    const confetti = document.createElement("div");
    confetti.className = "absolute inset-0 pointer-events-none";
    confetti.innerHTML = `
      <div class="confetti-container absolute inset-0 overflow-visible">
        ${Array.from({ length: 20 })
          .map(() => {
            const colors = [
              "#818cf8",
              "#a5b4fc",
              "#c7d2fe",
              "#6366f1",
              "#4f46e5",
            ];
            const color = colors[Math.floor(Math.random() * colors.length)];
            const x = Math.random() * 100 - 50;
            const y = Math.random() * -100 - 20;
            const rotation = Math.random() * 360;
            const scale = 0.5 + Math.random() * 0.5;
            const delay = Math.random() * 0.1;
            return `<div class="confetti-piece absolute left-1/2 top-1/2" style="--x: ${x}px; --y: ${y}px; --r: ${rotation}deg; --s: ${scale}; --delay: ${delay}s; background: ${color};"></div>`;
          })
          .join("")}
      </div>
    `;
    container.appendChild(confetti);
    return confetti;
  }

  function setupKudosForm(form: HTMLFormElement) {
    const button = form.querySelector<HTMLButtonElement>(".kudos-button");
    const totalEl = form.querySelector<HTMLSpanElement>(".kudos-total");
    const remainingEl = form.querySelector<HTMLSpanElement>(".kudos-remaining");

    if (!button || !totalEl || !remainingEl) return;

    let total = Number.parseInt(form.dataset.total || "0", 10);
    let you = Number.parseInt(form.dataset.you || "0", 10);
    let isSubmitting = false;

    // Generate fingerprint
    let clientId = localStorage.getItem("kudos_client_id");
    if (!clientId) {
      clientId = crypto.randomUUID();
      localStorage.setItem("kudos_client_id", clientId);
    }

    const ua = navigator.userAgent;
    const lang = navigator.language;
    const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    let fingerprint: string;
    try {
      fingerprint = btoa(`${clientId}:${ua}|${lang}|${tz}`).slice(0, 64);
    } catch {
      fingerprint = clientId;
    }

    // Also set cookie for no-JS fallback
    document.cookie = `kudos_client_id=${clientId}; path=/; max-age=31536000; samesite=lax`;

    const updateUI = () => {
      const remaining = Math.max(0, 50 - you);
      totalEl.textContent = String(total);
      remainingEl.textContent = String(remaining);

      if (remaining <= 0) {
        button.disabled = true;
        button.title = "Limit reached";
        button.classList.add("cursor-not-allowed", "border-current/20");
        button.classList.remove(
          "cursor-pointer",
          "hover:border-indigo-400",
          "hover:text-indigo-500",
          "hover:dark:text-indigo-300",
        );
      }
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const remaining = 50 - you;
      if (remaining <= 0 || isSubmitting) return;

      // Trigger confetti
      const confetti = createConfetti(form);
      setTimeout(() => confetti.remove(), 1000);

      // Optimistic update
      total++;
      you++;
      updateUI();
      isSubmitting = true;

      try {
        const response = await fetch("/api/kudos", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ slug: form.dataset.slug, fingerprint }),
        });

        const result = (await response.json()) as {
          ok?: boolean;
          total?: number;
          you?: number;
        };

        if (result.ok) {
          if (result.total !== undefined) total = result.total;
          if (result.you !== undefined) you = result.you;
          updateUI();
        } else {
          // Revert
          total--;
          you--;
          updateUI();
        }
      } catch {
        // Revert
        total--;
        you--;
        updateUI();
      } finally {
        isSubmitting = false;
      }
    });
  }

  // Initialize
  document
    .querySelectorAll<HTMLFormElement>(".kudos-form")
    .forEach(setupKudosForm);

  // Re-initialize after View Transitions
  document.addEventListener("astro:after-swap", () => {
    document
      .querySelectorAll<HTMLFormElement>(".kudos-form")
      .forEach(setupKudosForm);
  });
</script>

<style>
  .confetti-piece {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    animation: confetti-burst 0.6s ease-out forwards;
    animation-delay: var(--delay);
    opacity: 0;
  }

  @keyframes confetti-burst {
    0% {
      transform: translate(-50%, -50%) scale(0);
      opacity: 1;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translate(calc(-50% + var(--x)), calc(-50% + var(--y)))
        rotate(var(--r)) scale(var(--s));
      opacity: 0;
    }
  }
</style>
