{
  "name": "code",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:staging": "CLOUDFLARE_ENV=staging astro build",
    "preview": "astro preview",
    "deploy": "astro build && wrangler deploy --config dist/server/wrangler.json",
    "deploy:staging": "CLOUDFLARE_ENV=staging astro build && wrangler deploy --config dist/server/wrangler.json --env staging",
    "astro": "astro",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "astro check && tsc --noEmit",
    "generate:images": "npx tsx scripts/generate-images.ts",
    "generate:videos": "npx tsx scripts/generate-videos.ts",
    "generate:colors": "npx tsx scripts/generate-colors.ts",
    "upload:assets:production": "bash scripts/upload-assets.sh",
    "upload:assets:staging": "CLOUDFLARE_ENV=staging bash scripts/upload-assets.sh",
    "clean:videos:build": "find dist -name '*.mp4' -delete 2>/dev/null || true"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.1",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/react": "^5.0.0",
    "@astrojs/rss": "^4.0.17",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@codesandbox/sandpack-themes": "^2.0.21",
    "@epic-web/client-hints": "^1.3.8",
    "@resvg/resvg-wasm": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^6.0.4",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "fast-png": "^8.0.0",
    "framer-motion": "^13.0.0-alpha.0",
    "lucide-react": "^0.544.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "satori": "^0.10.13",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.4",
    "unist-util-visit": "^5.1.0",
    "use-scramble": "^2.2.15",
    "workers-og": "^0.0.27",
    "yoga-wasm-web": "^0.3.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@cloudflare/workers-types": "^4.20250926.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "24.0.4",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.2.3",
    "glob": "^11.0.3",
    "gray-matter": "^4.0.3",
    "happy-dom": "^20.0.0",
    "replicate": "^1.3.0",
    "tailwindcss": "^4.2.1",
    "typescript": "5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.61.1"
  }
}
