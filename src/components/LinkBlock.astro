---
interface Props {
  title: string;
  caption?: string | null;
  href: string;
  action?: string;
  description?: string;
}

const { title, caption, href, action = "View", description } = Astro.props;

const isExternal = action === "Open";
---

<a
  href={href}
  class="@container flex flex-col group hover:bg-gray-50 dark:hover:bg-gray-900 focus-visible:bg-gray-50 dark:focus-visible:bg-gray-900 relative before:content-[''] before:absolute before:left-0 before:top-0 before:h-full before:w-[2px] before:bg-transparent hover:before:bg-indigo-500 focus-visible:before:bg-indigo-500 px-4 py-3 gap-2 outline-none"
  rel={isExternal ? "noreferrer" : undefined}
  target={isExternal ? "_blank" : "_self"}
>
  <div class="flex justify-between leading-6">
    <div
      class:list={[
        "flex w-0 flex-1 flex-col @md:flex-row items-start @md:justify-between flex-wrap @lg:flex-nowrap gap-x-2",
        description ? "gap-y-2" : "gap-y-0"
      ]}
    >
      <span class="font-semibold dark:text-gray-200 leading-5 text-pretty font-mono">
        {title}
      </span>
      {caption && (
        <span class="mt-0.5 shrink-0 text-gray-400 dark:text-gray-500 text-xs font-sans border px-2 rounded-full border-gray-200 dark:border-gray-700">
          {caption}
        </span>
      )}
    </div>
    <div class="ml-4 shrink-0">
      <span class="mt-1 font-semibold font-mono text-indigo-600 group-hover:text-indigo-700 group-focus-visible:text-indigo-700 dark:text-indigo-400 dark:group-hover:text-indigo-300 dark:group-focus-visible:text-indigo-300 flex gap-2 items-center">
        <span class="@max-lg:hidden text-xs">{action}</span>
        {isExternal ? (
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 3h6v6"></path>
            <path d="M10 14 21 3"></path>
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          </svg>
        ) : (
          <span class="leading-none -mt-px">❯</span>
        )}
      </span>
    </div>
  </div>
  {description && (
    <div class="text-xs leading-5">
      <div class="overflow-hidden line-clamp-2 text-gray-400 dark:text-gray-500">
        {description}
      </div>
    </div>
  )}
</a>
