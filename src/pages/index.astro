---
import { getCollection } from "astro:content";
import About from "../components/About.astro";
import NavBlock from "../components/NavBlock.astro";
import Layout from "../layouts/Layout.astro";

// Get all posts and sort by date (extracted from filename)
const posts = await getCollection("posts");

// Extract date from filename pattern: YYYY-MM-DD.slug.mdx
const postsWithDates = posts
  .filter((post) => post.id !== "about") // Exclude about page
  .map((post) => {
    const dateMatch = post.id.match(/^(\d{4}-\d{2}-\d{2})\./);
    const date = dateMatch ? new Date(dateMatch[1]) : null;
    return { ...post, date };
  })
  .filter((post) => post.date !== null)
  .sort((a, b) => (b.date?.getTime() ?? 0) - (a.date?.getTime() ?? 0));

// Generate random video indices for each post
// Use 9 as default (images 0-8), but fall back to colors array length if available
const DEFAULT_VISUAL_COUNT = 9;
const videoIndices: Record<string, number> = {};
for (const post of postsWithDates) {
  const visualCount = post.data.visual?.colors?.length ?? DEFAULT_VISUAL_COUNT;
  videoIndices[post.data.slug] = Math.floor(Math.random() * visualCount);
}

// Strip markdown formatting from text
function stripMarkdown(text: string): string {
  return (
    text
      // Remove links but keep text: [text](url) -> text
      .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
      // Remove bold: **text** or __text__ -> text
      .replace(/\*\*([^*]+)\*\*/g, "$1")
      .replace(/__([^_]+)__/g, "$1")
      // Remove italic: *text* or _text_ -> text
      .replace(/\*([^*]+)\*/g, "$1")
      .replace(/_([^_]+)_/g, "$1")
      // Remove inline code: `code` -> code
      .replace(/`([^`]+)`/g, "$1")
      // Remove list markers: 1. or - or *
      .replace(/^\s*[\d]+\.\s+/gm, "")
      .replace(/^\s*[-*]\s+/gm, "")
      // Normalize whitespace
      .replace(/\s+/g, " ")
      .trim()
  );
}

// Extract excerpts from raw content (first few paragraphs)
function extractExcerpt(content: string, paragraphCount = 8): string {
  // Remove frontmatter if present
  const withoutFrontmatter = content.replace(/^---\n[\s\S]*?\n---\n/, "");

  const lines = withoutFrontmatter.split("\n");
  const paragraphs: string[] = [];
  let currentParagraph = "";
  let inCodeBlock = false;
  let inComponent = false;

  for (const line of lines) {
    if (line.trim().startsWith("```")) {
      inCodeBlock = !inCodeBlock;
      continue;
    }
    if (inCodeBlock) continue;

    if (line.trim().startsWith("<") && !line.trim().startsWith("</")) {
      inComponent = true;
    }
    if (line.trim().startsWith("</") || line.trim().endsWith("/>")) {
      inComponent = false;
      continue;
    }
    if (inComponent) continue;

    if (!line.trim() || line.trim().startsWith("#")) {
      if (currentParagraph.trim()) {
        paragraphs.push(stripMarkdown(currentParagraph.trim()));
        currentParagraph = "";
      }
      continue;
    }

    currentParagraph += (currentParagraph ? " " : "") + line.trim();
  }

  if (currentParagraph.trim()) {
    paragraphs.push(stripMarkdown(currentParagraph.trim()));
  }

  return paragraphs.slice(0, paragraphCount).join("\n\n");
}
---

<Layout title="❯ ~/code.charliegleason.com" description="Tutorials, code snippets, and resources for design and front end development">
  <div class="grid gap-4 sm:gap-8 content-end h-full">
    <h1 class="text-gray-400 dark:text-gray-500 font-mono font-semibold">
      ❯ cd ~/code.charliegleason.com
    </h1>
    
    <About />
    
    <div class="text-gray-900 dark:text-gray-100 bg-white dark:bg-gray-950 grid gap-4">
      <div class="nav-blocks-grid grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 3xl:grid-cols-6 4xl:grid-cols-7 gap-4">
        {postsWithDates.length > 0 ? (
          postsWithDates.map((post, idx) => (
            <NavBlock
              title={post.data.title}
              description={post.data.description}
              slug={post.data.slug}
              url={`/${post.data.slug}`}
              date={post.date ?? undefined}
              tags={post.data.tags}
              excerpt={idx === 0 ? extractExcerpt(post.body ?? "") : undefined}
              index={videoIndices[post.data.slug]}
              visual={post.data.visual}
              hero={idx === 0}
              className={idx === 0 ? "sm:col-span-2 3xl:col-span-3 sm:row-span-1 md:row-span-2" : ""}
            />
          ))
        ) : (
          <p class="flex items-center p-4 leading-6 text-gray-400">
            No posts found.
          </p>
        )}
      </div>
    </div>
  </div>
</Layout>
