---
import { getCollection } from "astro:content";
import Layout from "~/layouts/Layout.astro";

// Get the slug from the URL params
const { slug } = Astro.params;

// Find the post by slug
const posts = await getCollection("posts");
const post = posts.find((p) => p.data.slug === slug);

if (!post) {
  return Astro.redirect("/404");
}

// Get the number of visuals from the colors array or default to 9
const VISUAL_COUNT = post.data.visual?.colors?.length ?? 9;

// Generate array of image indices
const imageIndices = Array.from({ length: VISUAL_COUNT }, (_, i) => i);
---

<Layout title={`Social Grid for ${post.data.title} ❯ ~/code.charliegleason.com`} description={post.data.description}>
  <div class="space-y-4">
    <div class="flex flex-wrap gap-y-2 max-w-4xl font-mono">
      <a
        href="/"
        class="font-semibold group link-primary focus-ring-primary"
      >
        ❯ cd ~/code.charliegleason.com
      </a>
      <span class="text-yellow-500 dark:text-yellow-400 px-1">/</span>
      <a href={`/${slug}`} class="font-semibold text-yellow-500 dark:text-yellow-400 hover:text-yellow-600 dark:hover:text-yellow-300">
        {slug}
      </a>
      <span class="text-yellow-500 dark:text-yellow-400 px-1">/</span>
    </div>
    <h1 class="font-heading font-semibold text-gray-900 dark:text-gray-100 text-3xl max-w-4xl">
      Social Grid
    </h1>
    
    <p class="text-gray-500 dark:text-gray-400 font-mono text-sm max-w-4xl">
      Click on an image to view it full size. Hover to preview the video.
    </p>
    
    <div class="grid grid-cols-3 gap-4 max-w-4xl">
      {imageIndices.map((index) => {
        // Convert internal index to user-facing for URLs
        const userIndex = index + 1;
        const imageUrl = `/${slug}/${userIndex}.png`;
        const videoUrl = `/posts/${slug}/${index}.mp4`;
        
        return (
          <div class="card relative group">
            <a
              href={imageUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="block relative overflow-hidden rounded-lg"
              data-video-url={videoUrl}
            >
              <img
                src={imageUrl}
                alt={`Visual ${userIndex} for ${post.data.title}`}
                loading="lazy"
                class="w-full aspect-square object-cover transition-opacity"
              />
              <div class="absolute inset-0 left-auto z-10 pointer-events-none">
                <video
                  src={videoUrl}
                  muted
                  class="size-full object-cover opacity-0 group-hover:opacity-100 transition-opacity"
                  style="mask: linear-gradient(to right, transparent 0%, black 25%);"
                />
              </div>
            </a>
            <span class="absolute bottom-2 right-2 bg-black/50 text-white text-xs font-mono px-2 py-1 rounded">
              {userIndex}/{VISUAL_COUNT}
            </span>
          </div>
        );
      })}
    </div>
  </div>
</Layout>

<script>
  // Add hover behavior to play/pause videos
  document.querySelectorAll('.card').forEach((card) => {
    const video = card.querySelector('video') as HTMLVideoElement;
    if (!video) return;
    
    card.addEventListener('mouseenter', () => {
      video.currentTime = 0;
      video.play();
    });
    
    card.addEventListener('mouseleave', () => {
      video.pause();
      video.currentTime = 0;
    });
  });
</script>
